# Required for AI-generated pricing verdicts and rationale via Claude.
# Leave blank if using Ollama instead (see below), or leave both blank to
# use the deterministic rule-based fallback.
ANTHROPIC_API_KEY=

# Which AI provider to use: "anthropic", "ollama", or "none".
# If left blank, auto-detects: uses Claude if ANTHROPIC_API_KEY is set,
# otherwise tries Ollama at OLLAMA_BASE_URL, otherwise falls back to rules.
AI_PROVIDER=

# Local, free, no-API-key option. Install Ollama (https://ollama.com),
# run `ollama pull llama3.2`, then set AI_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Shared secret clients must send as the X-API-Key header.
ROI_API_KEY=demo-key-change-me

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5174
